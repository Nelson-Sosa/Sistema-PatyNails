rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // ─── USUARIOS ───
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId) && request.resource.data.role == "user";
      
      // El usuario puede actualizar su perfil, pero NO puede cambiarse el rol ni el estado de verificación
      allow update: if isOwner(userId) &&
        request.resource.data.get('role', 'user') == resource.data.get('role', 'user') &&
        request.resource.data.get('phoneVerified', false) == resource.data.get('phoneVerified', false) &&
        request.resource.data.get('uid', '') == resource.data.get('uid', '') &&
        request.resource.data.get('email', '') == resource.data.get('email', '');

      // El admin tiene control total
      allow write: if isAdmin();
    }

    // ─── CLIENTES ───
    match /clients/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── SETTINGS ───
    // settings/salon and settings/payments both live under /settings/{docId}
    match /settings/{docId} {
      // Everyone authenticated can read (needed for booking flow and public info)
      allow read: if isAuthenticated();
      // Only admins can write (bank data, payment config, etc.)
      allow write: if isAdmin();
    }

    // ─── SERVICIOS (Catálogo) ───
    match /services/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── CATEGORÍAS DE SERVICIOS ───
    match /serviceCategories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── TURNOS ───
    match /appointments/{docId} {
      // Admin tiene control total sobre todos los turnos
      allow read, write: if isAdmin();

      // Usuario: puede leer TODOS los turnos (necesario para verificar disponibilidad)
      allow read: if isAuthenticated();

      // Usuario: solo puede crear turnos a futuro y a su propio nombre
      allow create: if isAuthenticated()
        && request.resource.data.clientId == request.auth.uid
        && request.resource.data.date >= request.time;

      // Usuario: puede actualizar sus propios turnos en dos casos:
      //   1) Cancelar (status = 'cancelled') — regla original
      //   2) Subir/reemplazar comprobante de seña:
      //        - Solo modifica el campo 'payment' y 'updatedAt'
      //        - El nuevo payment.status debe ser 'proof_submitted'
      //        - El clientId del turno debe coincidir con el usuario autenticado
      //        - No puede cambiar otros campos del turno (status, date, price, etc.)
      allow update: if isAuthenticated()
        && resource.data.clientId == request.auth.uid
        && (
          // Case 1: Cancel
          (
            request.resource.data.status == 'cancelled' &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'updatedAt'])
          )
          ||
          // Case 2: Submit / replace proof (payment.status → proof_submitted)
          (
            request.resource.data.get('payment.status', '') == 'proof_submitted' &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['payment', 'updatedAt'])
          )
        );
    }

    // ─── INGRESOS ───
    match /income/{docId} {
      allow read, write: if isAdmin();
    }

    // ─── NOTIFICACIONES ───
    match /notifications/{docId} {
      // El admin puede ver, marcar como leídas, etc.
      allow read, write: if isAdmin();
      // Los usuarios autenticados pueden generar notificaciones (ej. al reservar un turno)
      allow create: if isAuthenticated();
    }

    // ─── HISTORIAL DE FIDELIDAD ───
    match /loyaltyHistory/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── TRABAJOS (PORTFOLIO) ───
    match /works/{workId} {
      // Admin: CRUD total
      allow read, write: if isAdmin();
      
      // Público no autenticado y clientes autenticados: pueden leer cualquier trabajo.
      allow read: if true;
      
      // Solo el admin puede crear, editar y eliminar trabajos.
      allow write: if isAdmin();
    }
  }
}
