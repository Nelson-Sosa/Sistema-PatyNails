# ════════════════════════════════════════════════════════════════
# MARBENAILS — Environment Variables Example
# ════════════════════════════════════════════════════════════════
# Este archivo SÍ se commitea al repositorio.
# Contiene la lista de variables requeridas (sin valores reales).
# Para configurar el proyecto: copiá este archivo como .env.local
# y completá con tus credenciales reales.
# ════════════════════════════════════════════════════════════════

# ── Firebase Configuration ────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ── App Configuration ─────────────────────────────────────────────
VITE_APP_ENV=

# ── Cloudinary (Módulo Trabajos) ──────────────────────────────────
VITE_CLOUDINARY_CLOUD_NAME=ddkl88iqk
VITE_CLOUDINARY_UPLOAD_PRESET=marbenails_works


